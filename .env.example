# 로컬 개발용 환경변수 예시. 복사해서 .env 로 만들어 채우세요. (.env 는 커밋 금지)

# PostgreSQL
DATABASE_URL=jdbc:postgresql://localhost:5432/maribel
DATABASE_DRIVER=org.postgresql.Driver
DATABASE_USERNAME=maribel
DATABASE_PASSWORD=change-this-local-password
JPA_DDL_AUTO=update

# Azure 앱 등록(개인 Microsoft 계정 허용)에서 발급한 값
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# 선택: 기본값을 바꿀 때만
# MICROSOFT_TENANT=consumers
# MICROSOFT_REDIRECT_URI=http://localhost:8080/api/auth/microsoft/callback
# MICROSOFT_SUCCESS_REDIRECT_URI=http://localhost:3000/auth/callback
# MICROSOFT_FAILURE_REDIRECT_URI=http://localhost:3000/login
# STELLA_WEBHOOK_SECRET=
# MARIBEL_BOOTSTRAP_ADMIN_PASSWORD=
